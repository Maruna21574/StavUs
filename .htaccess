<IfModule mod_rewrite.c>
    RewriteEngine On

    # Zablokovanie verejného prístupu k .git priečinku
    RewriteRule ^\.git/ - [F,L]

    # Presmerovanie zo starých .php URL na čisté (napr. /kontakt.php -> /kontakt)
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php[\s?] [NC]
    RewriteRule ^ %1 [R=301,L]

    # /index -> / (koreň)
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/index[\s?] [NC]
    RewriteRule ^index$ / [R=301,L]

    # Interné pripísanie .php k čistej URL (napr. /kontakt -> kontakt.php)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^([^/]+)/?$ $1.php [L]
</IfModule>
